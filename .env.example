# Required: Your LLM API key
BABEL_API_KEY=sk-your-api-key-here

# Optional: Model identifier (default: gpt-4o-mini)
# Supports 100+ models via litellm: gpt-4o, claude-3-5-sonnet, ollama/llama3, etc.
BABEL_MODEL=gpt-4o-mini

# Optional: Custom API base URL (default: https://api.openai.com/v1)
# BABEL_API_BASE=https://api.openai.com/v1

# Optional: Database path (default: ./babel.db)
# BABEL_DB_PATH=./babel.db
